rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOnlyConnectionsUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connections']);
    }

    function isActivityOwner(activityData) {
      return isAuthenticated() && activityData.userId == request.auth.uid;
    }

    // Fields a non-owner participant can touch
    function isParticipantUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['joiners']) ||
             affected.hasOnly(['joiners', 'paymentDetails']) ||
             affected.hasOnly(['paymentDetails']) ||
             affected.hasOnly(['joiners', 'departedJoiners']) ||
             affected.hasOnly(['joiners', 'departedJoiners', 'paymentDetails']);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        (
          isOnlyConnectionsUpdate() &&
          (
            (
              request.resource.data.connections != null &&
              request.resource.data.connections[request.auth.uid] != null
            ) ||
            resource.data.connections[request.auth.uid] != null
          )
        )
      );
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow list: if isAuthenticated();

      allow update: if isAuthenticated() && (
        // Owner can do anything
        isActivityOwner(resource.data) ||
        // Participants can update join/depart/payment fields only
        isParticipantUpdate()
      );

      // Only owner can delete (hard delete, for free events only per app logic)
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /payment_orders/{orderId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }
  }
}
